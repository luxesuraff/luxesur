---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { supabase } from "@/lib/supabase";

const SITE_URL = "https://www.luxesur.com";

/* =========================
FETCH DATA
========================= */

const { data: verticals } = await supabase
.from("verticals")
.select("slug,name")
.order("name");

const { data: metros } = await supabase
.from("metros")
.select("slug,city,state")
.eq("active",true)
.order("city")
.limit(50);

const { data: intents } = await supabase
.from("intents")
.select("slug,name,vertical_slug")
.eq("is_active",true)
.order("position");

/* =========================
HELPERS
========================= */

function intentsByVertical(verticalSlug){
return (intents || []).filter(i => i.vertical_slug === verticalSlug);
}

/* =========================
SEO
========================= */

const pageTitle = "Home Services Directory | Luxesur";

const canonicalUrl = `${SITE_URL}/services/`;

const alternateEn = `${SITE_URL}/en/services/`;
const alternateEs = `${SITE_URL}/es/services/`;

/* =========================
SCHEMA
========================= */

const breadcrumbSchema = {

"@context":"https://schema.org",
"@type":"BreadcrumbList",

itemListElement:[

{
"@type":"ListItem",
position:1,
name:"Home",
item:SITE_URL
},

{
"@type":"ListItem",
position:2,
name:"Services",
item:canonicalUrl
}

]

};

const serviceListSchema = {

"@context":"https://schema.org",
"@type":"ItemList",

name:"Home Services Directory",

itemListElement:verticals?.map((v,i)=>({

"@type":"ListItem",
position:i+1,
name:v.name,
url:`${SITE_URL}/en/${v.slug}/`

}))

};

---

<BaseLayout
title={pageTitle}
canonical={canonicalUrl}
hreflang={{
en:alternateEn,
es:alternateEs,
xDefault:alternateEn
}}
lang="en"
>

<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(serviceListSchema)} />

<h1>Home Service Resources</h1>

<p>
Luxesur provides informational resources covering common residential service needs across major metropolitan areas in the United States.
Browse service categories below to view available city pages and learn about services available in your area.
</p>

{/* =========================
VERTICAL DIRECTORY
========================= */}

<section>

<h2>Service Categories</h2>

<ul>

{verticals?.map((v)=> (

<li>

<a href={`/en/${v.slug}/`}>
{v.name}
</a>

</li>

))}

</ul>

</section>

{/* =========================
FEATURED SERVICE PAGES
========================= */}

<section>

<h2>Popular Service Searches</h2>

<ul>

{verticals?.flatMap((v)=>{

const verticalIntents = intentsByVertical(v.slug).slice(0,3);

return verticalIntents.map(intent => (

<li>

<a href={`/en/${v.slug}/`}>
{intent.name}
</a>

</li>

));

})}

</ul>

</section>

{/* =========================
CITY DISCOVERY
========================= */}

<section>

<h2>Cities With Service Coverage</h2>

<ul>

{metros?.map((m)=> (

<li>

<a href={`/en/emergency-plumbing/${m.slug}/`}>
Emergency Plumbing in {m.city}, {m.state}
</a>

</li>

))}

</ul>

</section>

{/* =========================
ABOUT
========================= */}

<section>

<h2>How Luxesur Works</h2>

<p>
Luxesur operates as an informational directory designed to help users understand common residential service needs and connect with independent service providers in their area.
Content across the platform is organized by service category and metropolitan region to help visitors locate relevant information quickly.
</p>

<p>
Each service category includes pages covering major cities and surrounding communities where independent providers may offer assistance with common household service needs.
</p>

</section>

</BaseLayout>