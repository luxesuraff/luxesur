---
type Props = {
  phoneNumber?: string | null;
  label?: string;
  subtext?: string;
  className?: string;
  lang?: string;
};

const {
  phoneNumber = null,
  label = "Call Now",
  subtext = "",
  className = "cta",
  lang = "en"
} = Astro.props;

/*
PRESENTATIONAL COMPONENT ONLY
All business logic stays in page files
*/
---

{phoneNumber ? (

  <a
    href={`tel:${phoneNumber}`}
    class={className}
    rel="nofollow"
    role="button"
    aria-label={`${label} ${phoneNumber}`}
  >
    <span class="cta-label">{label}</span>

    {subtext && (
      <small class="cta-subtext">
        {subtext}
      </small>
    )}

  </a>

) : (

  <a
    href={`/${lang}/cities/`}
    class={className}
    role="button"
  >
    <span class="cta-label">
      Cities We Serve
    </span>

  </a>

)}