---
import Pixels from "@/components/Pixels.astro";
import { Astro } from "astro";

const {
  title,
  breadcrumbs = null,
  faqs = null,
  canonical = null,
  hreflang = null,
  lang = "en"
} = Astro.props;

/* =========================
   CANONICAL LOGIC
========================= */

const canonicalUrl =
  canonical ??
  new URL(Astro.request.url).origin + Astro.url.pathname;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <title>{title}</title>

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO META -->
    <meta name="robots" content="index, follow, max-image-preview:large" />

    <!-- CANONICAL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- HREFLANG -->
    {hreflang?.en && (
      <link rel="alternate" hrefLang="en" href={hreflang.en} />
    )}

    {hreflang?.es && (
      <link rel="alternate" hrefLang="es" href={hreflang.es} />
    )}

    {hreflang?.xDefault && (
      <link rel="alternate" hrefLang="x-default" href={hreflang.xDefault} />
    )}

    <!-- GOOGLE TAG (GA4) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-ZMDPYFW90C"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-ZMDPYFW90C');
    </script>

    <!-- WEBSITE SCHEMA -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebSite",
        name: "Luxesur",
        url: "https://www.luxesur.com",
        description:
          "Luxesur is a consumer-facing informational and referral platform connecting users with independent third-party service providers.",
        publisher: {
          "@type": "Organization",
          name: "Luxesur",
          url: "https://www.luxesur.com",
        },
      })}
    </script>

    <!-- ORGANIZATION SCHEMA -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Organization",
        name: "Luxesur",
        url: "https://www.luxesur.com",
        description:
          "Luxesur operates as an informational and referral platform.",
      })}
    </script>

    <!-- FAQ SCHEMA -->
    {faqs && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "FAQPage",
          mainEntity: faqs.map((f) => ({
            "@type": "Question",
            name: f.question,
            acceptedAnswer: {
              "@type": "Answer",
              text: f.answer,
            },
          })),
        })}
      />
    )}

    <!-- BREADCRUMB SCHEMA -->
    {breadcrumbs && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "BreadcrumbList",
          itemListElement: breadcrumbs.map((item, i) => ({
            "@type": "ListItem",
            position: i + 1,
            name: item.name,
            item: item.url,
          })),
        })}
      />
    )}

    <!-- PIXELS -->
    <Pixels />

    <style>
      body {
        font-family: Arial, Helvetica, sans-serif;
        margin: 0;
        padding: 0;
        line-height: 1.6;
        color: #111;
      }

      main {
        max-width: 900px;
        margin: 40px auto;
        padding: 0 20px;
      }

      nav.breadcrumbs {
        font-size: 14px;
        margin-bottom: 20px;
        color: #666;
      }

      nav.breadcrumbs a {
        color: #0b5ed7;
      }

      footer {
        margin-top: 80px;
        padding: 20px;
        font-size: 14px;
        border-top: 1px solid #eee;
        text-align: center;
      }

      a {
        color: #0b5ed7;
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .geo-hub {
        margin-top: 30px;
        font-size: 14px;
      }
    </style>
  </head>

  <body>

    <main>

      <!-- HTML BREADCRUMBS (CRAWLABLE LINKS) -->
      {breadcrumbs && (
        <nav class="breadcrumbs">
          {breadcrumbs.map((b, i) => (
            <>
              <a href={b.url}>{b.name}</a>
              {i < breadcrumbs.length - 1 && " > "}
            </>
          ))}
        </nav>
      )}

      <slot />

      <!-- GEO DISCOVERY LINKS -->
      <div class="geo-hub">
        <strong>Service Areas</strong><br />
        <a href="/cities/">Cities We Serve</a>
      </div>

    </main>

    <footer>
      <a href="/">Home</a> |
      <a href="/cities/">Cities</a> |
      <a href="/about">About</a> |
      <a href="/contact">Contact</a> |
      <a href="/disclosures">Disclosures</a> |
      <a href="/privacy">Privacy</a> |
      <a href="/terms">Terms</a>
      <a href="/crawl-map/">Coverage Map</a>
    </footer>

  </body>
</html>