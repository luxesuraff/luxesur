---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import CallCTA from "@/components/CallCTA.astro";

import { supabase } from "@/lib/supabase";

const SITE_URL = "https://www.luxesur.com";

function injectLocation(text, city, state) {
  if (!text) return "";
  return text.replaceAll("{city}", city).replaceAll("{state}", state);
}

function formatHeading(text) {
  if (!text) return "";
  return text
    .replaceAll("-", " ")
    .replace(/\b\w/g, (l) => l.toUpperCase());
}

const { lang, vertical, metro, service } = Astro.params;

if (!lang || !vertical || !metro || !service) {
  return new Response("Not found", { status: 404 });
}

const { data: verticalData } = await supabase
  .from("verticals")
  .select("id,name,hero_image")
  .eq("slug", vertical)
  .maybeSingle();

if (!verticalData) {
  return new Response("Not found", { status: 404 });
}

const { data: metroData } = await supabase
  .from("metros")
  .select("city,state")
  .eq("slug", metro)
  .eq("active", true)
  .maybeSingle();

if (!metroData) {
  return new Response("Not found", { status: 404 });
}

const city = metroData.city;
const state = metroData.state;

const { data: serviceData } = await supabase
  .from("intents")
  .select("slug,name")
  .eq("slug", service)
  .eq("vertical_slug", vertical)
  .eq("is_active", true)
  .maybeSingle();

if (!serviceData) {
  return new Response("Not found", { status: 404 });
}

const { data: contentBlocks } = await supabase
  .from("intent_content_blocks")
  .select("section,content,body")
  .eq("intent_slug", service)
  .eq("language_code", lang)
  .order("position");

const blocks = contentBlocks || [];
const seen = new Set();
const finalBlocks = [];

for (const b of blocks) {
  const section = (b.section || "").toLowerCase().trim();
  const content = b.content || b.body || "";

  if (!section || !content) continue;
  if (seen.has(section)) continue;

  seen.add(section);

  finalBlocks.push({
    section,
    content
  });
}

const limitedBlocks = finalBlocks.slice(0, 12);

const { data: suburbData } = await supabase
  .from("suburbs")
  .select("name,city,slug")
  .eq("metro_slug", metro)
  .limit(20);

const suburbs = (suburbData || []).map((s) => ({
  slug: s.slug,
  name: s.name || s.city
}));

const { data: otherServices } = await supabase
  .from("intents")
  .select("slug,name")
  .eq("vertical_slug", vertical)
  .neq("slug", service)
  .eq("is_active", true);

const relatedServices = (otherServices || []).slice(0, 6);

const { data: sameState } = await supabase
  .from("metros")
  .select("slug,city,state")
  .eq("state", state)
  .neq("slug", metro)
  .eq("active", true)
  .limit(10);

const nearbyMetros = sameState || [];

const pageTitle = `${serviceData.name} in ${city}, ${state} | Luxesur`;

const metaDescription =
  `${serviceData.name} services in ${city}, ${state}. Emergency plumbing coverage including burst pipes and sewer backups.`;

const canonicalUrl = `${SITE_URL}/${lang}/${vertical}/${metro}/${service}/`;
const heroImage = verticalData.hero_image || "/images/default.webp";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `${serviceData.name} in ${city}, ${state}`,
  areaServed: {
    "@type": "City",
    name: city
  },
  provider: {
    "@type": "Organization",
    name: "Luxesur",
    url: SITE_URL
  }
};
---

<BaseLayout title={pageTitle} description={metaDescription} canonical={canonicalUrl} lang={lang}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <Hero src={heroImage} alt={`${serviceData.name} in ${city}, ${state}`}>
    <CallCTA />
  </Hero>

  <h1>{serviceData.name} in {city}, {state}</h1>

  {limitedBlocks.map((b) => (
    <section>
      <h2>{formatHeading(b.section)}</h2>
      <p>{injectLocation(b.content, city, state)}</p>
    </section>
  ))}

  {suburbs.length > 0 && (
    <section>
      <h2>{lang === "es" ? `Áreas cercanas en ${city}` : `Nearby Service Areas in ${city}`}</h2>
      <ul>
        {suburbs.map((s) => (
          <li>
            <a href={`/${lang}/${vertical}/${metro}/${service}/${s.slug}/`}>{s.name}</a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {relatedServices.length > 0 && (
    <section>
      <h2>{lang === "es" ? "Otros servicios" : "Other Services"}</h2>
      <ul>
        {relatedServices.map((s) => (
          <li>
            <a href={`/${lang}/${vertical}/${metro}/${s.slug}/`}>{s.name} in {city}</a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {nearbyMetros.length > 0 && (
    <section>
      <h2>{lang === "es" ? "Ciudades cercanas" : "Nearby Cities We Serve"}</h2>
      <ul>
        {nearbyMetros.map((m) => (
          <li>
            <a href={`/${lang}/${vertical}/${m.slug}/${service}/`}>
              {serviceData.name} in {m.city}, {m.state}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section>
    <h2>{lang === "es" ? "Cobertura de servicio" : "Service Coverage"}</h2>
    <ul>
      {nearbyMetros.slice(0, 8).map((m) => (
        <li>
          <a href={`/${lang}/${vertical}/${m.slug}/`}>{verticalData.name} in {m.city}</a>
        </li>
      ))}
    </ul>
  </section>

  <footer>
    <nav>
      <h3>{lang === "es" ? "Explorar" : "Explore"}</h3>
      <ul>
        <li><a href={`/${lang}/cities/`}>Cities</a></li>
        <li><a href={`/${lang}/services/`}>Services</a></li>
        <li><a href={`/${lang}/${vertical}/`}>{verticalData.name}</a></li>
        <li><a href="/crawl-map/">Coverage Map</a></li>
      </ul>
    </nav>
  </footer>
</BaseLayout>
