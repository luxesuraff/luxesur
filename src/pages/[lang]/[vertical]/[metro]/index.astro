---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import CallCTA from "@/components/CallCTA.astro";
import RelatedMetros from "@/components/RelatedMetros.astro";

import { supabase } from "@/lib/supabase";

const SITE_URL = "https://www.luxesur.com";

function injectLocation(text, city, state) {
  if (!text) return "";
  return text.replaceAll("{city}", city).replaceAll("{state}", state);
}

function formatHeading(text) {
  if (!text) return "";
  return text
    .replaceAll("-", " ")
    .replace(/\b\w/g, (l) => l.toUpperCase());
}

const { lang, vertical, metro } = Astro.params;

if (!lang || !vertical || !metro) {
  return new Response("Not found", { status: 404 });
}

const { data: verticalData } = await supabase
  .from("verticals")
  .select("id,name,hero_image")
  .eq("slug", vertical)
  .maybeSingle();

if (!verticalData) {
  return new Response("Not found", { status: 404 });
}

const { data: metroData } = await supabase
  .from("metros")
  .select("slug,city,state,seo_intro,region_name")
  .eq("slug", metro)
  .eq("active", true)
  .maybeSingle();

if (!metroData) {
  return new Response("Not found", { status: 404 });
}

const city = metroData.city;
const state = metroData.state;
const region = metroData.region_name || state;

const { data: intents } = await supabase
  .from("intents")
  .select("slug,name")
  .eq("vertical_slug", vertical)
  .eq("is_active", true)
  .order("position");

const services = intents || [];

const { data: suburbData } = await supabase
  .from("suburbs")
  .select("slug,name,city")
  .eq("metro_slug", metro)
  .order("name")
  .limit(25);

const suburbs = (suburbData || []).map((s) => ({
  slug: s.slug,
  name: s.name || s.city
}));

const { data: contentBlocks } = await supabase
  .from("intent_content_blocks")
  .select("id,heading,section,body,content")
  .eq("vertical_slug", vertical)
  .eq("language_code", lang)
  .order("position");

const seen = new Set();
const uniqueBlocks = [];

for (const b of contentBlocks || []) {
  const key = `${b.heading || b.section}-${b.body || b.content}`;
  if (seen.has(key)) continue;
  seen.add(key);
  uniqueBlocks.push(b);
}

const blocks = uniqueBlocks.slice(0, 10);

const { data: related } = await supabase
  .from("metros")
  .select("city,slug")
  .eq("state", state)
  .neq("slug", metro)
  .eq("active", true)
  .limit(8);

const relatedMetros = related || [];

let phoneNumber = null;

const { data: ctaProfile } = await supabase
  .from("cta_profiles")
  .select("phone_number,is_active")
  .eq("vertical_id", verticalData.id)
  .eq("language_code", lang)
  .maybeSingle();

if (ctaProfile?.is_active) {
  phoneNumber = ctaProfile.phone_number;
}

const pageTitle = `${verticalData.name} in ${city}, ${state} | Luxesur`;
const metaDescription = `${verticalData.name} resources and service coverage in ${city}, ${state}.`;
const canonicalUrl = `${SITE_URL}/${lang}/${vertical}/${metro}/`;

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: `${verticalData.name} in ${city}, ${state}`,
  areaServed: {
    "@type": "City",
    name: city
  },
  provider: {
    "@type": "Organization",
    name: "Luxesur",
    url: SITE_URL
  }
};
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonical={canonicalUrl}
  lang={lang}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <Hero src={verticalData.hero_image || "/images/default.webp"} alt={pageTitle}>
    <CallCTA phoneNumber={phoneNumber} />
  </Hero>

  <h1>{verticalData.name} in {city}, {state}</h1>

  <p>
    {verticalData.name} services may be available in {city}, {state} and surrounding areas within the {region} region.
  </p>

  {services.length > 0 && (
    <section>
      <h2>{lang === "es" ? `Servicios disponibles en ${city}` : `${verticalData.name} Services in ${city}`}</h2>
      <ul>
        {services.map((s) => (
          <li>
            <a href={`/${lang}/${vertical}/${metro}/${s.slug}/`}>{s.name} in {city}</a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {blocks.map((b) => (
    <section>
      <h2>{formatHeading(b.heading || b.section)}</h2>
      <p>{injectLocation(b.body || b.content, city, state)}</p>
    </section>
  ))}

  {suburbs.length > 0 && services.length > 0 && (
    <section>
      <h2>{lang === "es" ? `Áreas cercanas en ${city}` : `Nearby Areas in ${city}`}</h2>
      <ul>
        {suburbs.map((s) => (
          <li>
            {services.map((svc) => (
              <div>
                <a href={`/${lang}/${vertical}/${metro}/${svc.slug}/${s.slug}/`}>{svc.name} in {s.name}</a>
              </div>
            ))}
          </li>
        ))}
      </ul>
    </section>
  )}

  {relatedMetros.length > 0 && (
    <section>
      <h2>{lang === "es" ? "Ciudades cercanas" : "Nearby Cities"}</h2>
      <ul>
        {relatedMetros.map((m) => (
          <li>
            <a href={`/${lang}/${vertical}/${m.slug}/`}>{verticalData.name} in {m.city}, {state}</a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section>
    <h2>{lang === "es" ? "Cobertura de servicio" : "Service Coverage"}</h2>
    <ul>
      {relatedMetros.map((m) => (
        <li>
          <a href={`/${lang}/${vertical}/${m.slug}/`}>{verticalData.name} in {m.city}</a>
        </li>
      ))}
    </ul>
  </section>

  <RelatedMetros metros={relatedMetros} lang={lang} vertical={vertical} />
</BaseLayout>
