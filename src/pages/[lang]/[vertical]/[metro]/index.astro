---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import CallCTA from "@/components/CallCTA.astro";
import RelatedMetros from "@/components/RelatedMetros.astro";

import { supabase } from "@/lib/supabase";
import { supabaseAdmin } from "@/lib/supabaseAdmin";

const SITE_URL = "https://www.luxesur.com";

/* =========================
HELPERS
========================= */

function injectLocation(text: string | null | undefined, city: string, state: string) {
  if (!text) return "";

  return text
    .replaceAll("{city}", city)
    .replaceAll("{state}", state);
}

function formatHeading(text: string | null | undefined) {
  if (!text) return "";

  const map: Record<string, string> = {
    intro: "Emergency Plumbing Overview",
    "service-overview": "Service Overview",
    "common-causes": "Common Causes",
    causes: "Common Causes",
    "inspection-process": "Inspection Process",
    "repair-options": "Repair Options",
    "local-context": "Local Context",
    prevention: "Prevention",
    closing: "Service Summary",
    "burst-pipe": "Burst Pipe Repair",
    "burst-pipe-repair": "Burst Pipe Repair",
    "leak-detection": "Leak Detection",
    "drain-blockage": "Drain Blockages",
    "drain-blockages": "Drain Blockages",
    "water-heater": "Water Heater Issues",
    "water-heater-issues": "Water Heater Issues",
    "sewer-line": "Sewer Line Problems",
    "sewer-line-problems": "Sewer Line Problems",
    "emergency-response": "Emergency Response",
    "damage-prevention": "Preventing Water Damage",
    "water-damage-prevention": "Preventing Water Damage",
    "professional-equipment": "Professional Equipment",
    "equipment-used": "Professional Equipment"
  };

  if (map[text]) return map[text];

  return text
    .replaceAll("-", " ")
    .replace(/\b\w/g, (l) => l.toUpperCase());
}

/* =========================
STATIC PATHS
========================= */

export async function getStaticPaths() {
  const { data: metros } = await supabaseAdmin
    .from("metros")
    .select("slug,city,state")
    .eq("active", true);

  const { data: verticals } = await supabaseAdmin
    .from("verticals")
    .select("slug");

  const languages = ["en", "es"];
  const paths = [];

  for (const lang of languages) {
    for (const v of verticals || []) {
      for (const m of metros || []) {
        paths.push({
          params: {
            lang,
            vertical: v.slug,
            metro: m.slug
          },
          props: {
            city: m.city,
            state: m.state
          }
        });
      }
    }
  }

  return paths;
}

/* =========================
PARAMS
========================= */

const { lang, vertical, metro } = Astro.params;
const { city, state } = Astro.props as { city: string; state: string };

if (!lang || !["en", "es"].includes(lang)) {
  throw new Error("Invalid language");
}

if (!vertical || !metro) {
  throw new Error("Missing route params");
}

/* =========================
VERTICAL DATA
========================= */

const { data: verticalData } = await supabase
  .from("verticals")
  .select("id,name,hero_image")
  .eq("slug", vertical)
  .maybeSingle();

if (!verticalData) {
  throw new Error(`Vertical not found: ${vertical}`);
}

/* =========================
METRO DATA
========================= */

const { data: metroData } = await supabase
  .from("metros")
  .select("seo_intro,region_name")
  .eq("slug", metro)
  .maybeSingle();

const region = metroData?.region_name || state;
const seoIntro = metroData?.seo_intro || null;

/* =========================
INTENTS / SERVICES
========================= */

const { data: intents } = await supabase
  .from("intents")
  .select("slug,name")
  .eq("vertical_slug", vertical)
  .eq("is_active", true)
  .order("position");

const services = intents || [];

/* =========================
CONTENT BLOCKS
METRO PAGE USES VERTICAL SLUG
========================= */

const { data: contentBlocks } = await supabase
  .from("intent_content_blocks")
  .select("*")
  .eq("intent_slug", vertical)
  .eq("language_code", lang)
  .order("position");

const blocks = contentBlocks || [];

/* dedupe by heading first, then body */
const uniqueBlocks: any[] = [];
const seen = new Set<string>();

for (const b of blocks) {
  const heading = String(b.heading || b.section || "").trim();
  const body = String(b.body || b.content || "").trim();

  const key = `${heading}::${body}`;

  if (!seen.has(key) && body) {
    uniqueBlocks.push(b);
    seen.add(key);
  }
}

/* =========================
RELATED METROS
========================= */

const { data: related } = await supabase
  .from("metros")
  .select("city,slug")
  .eq("state", state)
  .neq("slug", metro)
  .eq("active", true)
  .order("city")
  .limit(8);

const relatedMetros = related || [];

/* =========================
FAQ
========================= */

let faqItems: Array<{ question: string; answer: string; position: number }> = [];

const { data: faqSet } = await supabase
  .from("faq_sets")
  .select("id")
  .eq("slug", `${vertical}-core`)
  .eq("language_code", lang)
  .maybeSingle();

if (faqSet?.id) {
  const { data: faqData } = await supabase
    .from("faq_items")
    .select("question,answer,position")
    .eq("faq_set_id", faqSet.id)
    .eq("is_active", true)
    .order("position");

  faqItems = faqData || [];
}

/* =========================
CTA
========================= */

let phoneNumber: string | null = null;
let ctaLabel = lang === "es" ? "Llamar Ahora" : "Call Now";
let ctaSubtext = lang === "es" ? "Servicio 24/7" : "24/7 Service";

const { data: ctaSettings } = await supabase
  .from("vertical_cta_settings")
  .select("calls_enabled")
  .eq("vertical_id", verticalData.id)
  .eq("language_code", lang)
  .maybeSingle();

const callsEnabled = Boolean(ctaSettings?.calls_enabled);

if (callsEnabled) {
  const { data: ctaProfile } = await supabase
    .from("cta_profiles")
    .select("phone_number,cta_label,cta_subtext,is_active")
    .eq("vertical_id", verticalData.id)
    .eq("language_code", lang)
    .maybeSingle();

  if (ctaProfile?.is_active && ctaProfile?.phone_number) {
    phoneNumber = ctaProfile.phone_number;
    ctaLabel = ctaProfile.cta_label || ctaLabel;
    ctaSubtext = ctaProfile.cta_subtext || ctaSubtext;
  }
}

/* =========================
SEO
========================= */

const pageTitle =
  lang === "es"
    ? `${verticalData.name} en ${city}, ${state} | Luxesur`
    : `${verticalData.name} in ${city}, ${state} | Luxesur`;

const metaDescription =
  lang === "es"
    ? `Recursos informativos sobre ${verticalData.name} en ${city}, ${state}.`
    : `Informational resources about ${verticalData.name} in ${city}, ${state}.`;

const canonicalUrl = `${SITE_URL}/${lang}/${vertical}/${metro}/`;
const alternateEn = `${SITE_URL}/en/${vertical}/${metro}/`;
const alternateEs = `${SITE_URL}/es/${vertical}/${metro}/`;

/* =========================
SCHEMA
========================= */

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: lang === "es"
    ? `${verticalData.name} en ${city}, ${state}`
    : `${verticalData.name} in ${city}, ${state}`,
  areaServed: {
    "@type": "City",
    name: city
  },
  provider: {
    "@type": "Organization",
    name: "Luxesur",
    url: SITE_URL
  }
};
---

<BaseLayout
  title={pageTitle}
  description={metaDescription}
  canonical={canonicalUrl}
  hreflang={{
    en: alternateEn,
    es: alternateEs,
    xDefault: alternateEn
  }}
  lang={lang}
  faqs={faqItems}
>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

  <Hero
    src={verticalData.hero_image || "/images/default.webp"}
    alt={pageTitle}
  >
    <CallCTA
      phoneNumber={phoneNumber}
      label={ctaLabel}
      subtext={ctaSubtext}
      lang={lang}
    />
  </Hero>

  <h1>{pageTitle}</h1>

  <p>
    {lang === "es"
      ? `${verticalData.name} puede estar disponible en ${city}, ${state} y áreas cercanas dentro de la región ${region}.`
      : `${verticalData.name} services may be available in ${city}, ${state} and surrounding areas in the ${region} region.`}
  </p>

  {seoIntro && (
    <p>{injectLocation(seoIntro, city, state)}</p>
  )}

  <section>
    <h2>
      {lang === "es"
        ? `Servicios de ${verticalData.name} disponibles en ${city}`
        : `${verticalData.name} Services Available in ${city}`}
    </h2>

    {services.length > 0 ? (
      <ul>
        {services.map((s) => (
          <li>
            <a href={`/${lang}/${vertical}/${metro}/${s.slug}/`}>
              {lang === "es"
                ? `${s.name} en ${city}`
                : `${s.name} in ${city}`}
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p>
        {lang === "es"
          ? "No hay servicios disponibles en este momento."
          : "No services are available at this time."}
      </p>
    )}
  </section>

  {uniqueBlocks.map((b) => (
    <section>
      <h2>{formatHeading(b.heading || b.section)}</h2>
      <p>{injectLocation(b.body || b.content, city, state)}</p>
    </section>
  ))}

  {relatedMetros.length > 0 && (
    <section>
      <h2>
        {lang === "es" ? `Ciudades cerca de ${city}` : `Cities Near ${city}`}
      </h2>

      <ul>
        {relatedMetros.map((m) => (
          <li>
            <a href={`/${lang}/${vertical}/${m.slug}/`}>
              {lang === "es"
                ? `${verticalData.name} en ${m.city}, ${state}`
                : `${verticalData.name} in ${m.city}, ${state}`}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <RelatedMetros
    metros={relatedMetros}
    lang={lang}
    vertical={vertical}
  />
</BaseLayout>