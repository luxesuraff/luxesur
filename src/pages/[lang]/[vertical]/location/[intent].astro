---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Hero from "../../../components/Hero.astro";
import CallCTA from "../../../components/CallCTA.astro";
import { supabase } from "../../../lib/supabase";
import { VERTICALS } from "../../../config/verticals";

/* ---------------------------------------
   STATIC PATHS (METRO ONLY)
--------------------------------------- */
export async function getStaticPaths() {
  const { data: metros, error } = await supabase
    .from("locations")
    .select("slug")
    .eq("type", "metro")
    .eq("is_active", true);

  if (error) {
    throw new Error(error.message);
  }

  const verticals = Object.keys(VERTICALS);
  const paths = [];

  for (const v of verticals) {
    const intents = VERTICALS[v].intents;

    for (const metro of metros || []) {
      for (const intent of intents) {
        paths.push({
          params: {
            vertical: v,
            location: metro.slug,
            intent,
          },
        });
      }
    }
  }

  return paths;
}

/* ---------------------------------------
   PAGE DATA
--------------------------------------- */
const { vertical, location, intent } = Astro.params;

if (!VERTICALS[vertical]) {
  throw new Error(`Invalid vertical: ${vertical}`);
}

const verticalConfig = VERTICALS[vertical];

if (!verticalConfig.intents.includes(intent)) {
  throw new Error(`Invalid intent "${intent}" for ${vertical}`);
}

const { data: locationData, error } = await supabase
  .from("locations")
  .select("*")
  .eq("slug", location)
  .eq("type", "metro")
  .single();

if (error || !locationData) {
  throw new Error(`Metro not found or invalid for intent page: ${location}`);
}

/* ---------------------------------------
   SEO DATA
--------------------------------------- */

const intentLabel = intent.replace(/-/g, " ");
const capitalizedIntent =
  intentLabel.charAt(0).toUpperCase() + intentLabel.slice(1);

const pageTitle = `${capitalizedIntent} in ${locationData.name}, ${locationData.state_abbr}`;
const metaDescription = `24/7 ${intentLabel} service in ${locationData.name}, ${locationData.state_abbr}. Fast emergency response available.`;

---

<BaseLayout title={pageTitle} description={metaDescription}>

  {/* HERO */}
  <Hero
    title={`${capitalizedIntent} in ${locationData.name}, ${locationData.state_abbr}`}
    subtitle="24/7 Emergency Service"
    intent={`${vertical}-${intent}`}
  />

  {/* PRIMARY CONTENT */}
  <section>
    <h2>${capitalizedIntent} Services</h2>
    <p>
      Immediate emergency response for ${intentLabel} in ${locationData.name}.
      Fast professional service helps reduce damage and restore safety.
    </p>
    <CallCTA intent={`${vertical}-${intent}`} />
  </section>

  {/* BACK TO PRIMARY PAGE */}
  <section>
    <h3>More ${verticalConfig.label} in ${locationData.name}</h3>
    <a href={`/${vertical}/${location}`}>
      View all emergency ${vertical} services
    </a>
  </section>

</BaseLayout>