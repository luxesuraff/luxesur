---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { cities } from "@/data/cities";
import { INTENT_CONFIG } from "@/config/intents";
import Hero from "@/components/Hero.astro";

export async function getStaticPaths() {
  return cities.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props;
const cityName = city.city;
const state = city.state;

// 🔒 LOCKED INTENT KEY
const intent = "emergency-plumbing";
const intentConfig = INTENT_CONFIG[intent];

const pageTitle = `Emergency Plumbing in ${cityName}, ${state} | Local Help Available`;
const metaDescription = `Need emergency plumbing in ${cityName}, ${state}? Get help for urgent plumbing issues like leaks, sewer backups, and sudden water loss.`;

const currentIndex = cities.findIndex(c => c.slug === city.slug);
const nearbyCities = cities
  .slice(currentIndex + 1, currentIndex + 7)
  .filter(Boolean);
---

<BaseLayout title={pageTitle} description={metaDescription}>

  <!-- HERO (CTA GATED SAFELY) -->
  <Hero
    src="/images/emergency-plumbing/emergency/hero.webp"
    alt={`Emergency plumbing help in ${cityName}, ${state}`}
    phone={intentConfig?.ctaEnabled ? intentConfig.phone : null}
  />

  <!-- INTRO -->
  <section class="hero">
    <h1>Emergency Plumbing in {cityName}, {state}</h1>

    <p>
      Plumbing emergencies can cause serious damage if not addressed quickly.
      Issues such as burst pipes, sewer backups, or sudden water loss may require
      immediate attention to prevent further damage.
    </p>

    <p>
      If you are dealing with an urgent plumbing problem in {cityName}, {state},
      help may be available through independent emergency plumbing professionals
      serving the area.
    </p>
  </section>

  <!-- DEFINITIONS -->
  <section>
    <h2>What Is Considered a Plumbing Emergency?</h2>
    <ul>
      <li>Burst or severely leaking pipes</li>
      <li>Sewer backups or overflowing drains</li>
      <li>No running water or sudden pressure loss</li>
      <li>Water heater failures causing water damage</li>
    </ul>
  </section>

  <!-- WHY SPEED MATTERS -->
  <section>
    <h2>Why Fast Emergency Plumbing Response Matters</h2>
    <p>
      Emergency plumbing issues can escalate quickly if left unresolved.
      Prompt response may help limit property damage, reduce repair costs,
      and restore safe use of plumbing systems.
    </p>
  </section>

  <!-- 🔥 DEPTH BLOCK (THIS WAS MISSING BEFORE) -->
  <section>
    <h2>Common Emergency Plumbing Situations in {cityName}, {state}</h2>

    <p>
      Homes and commercial properties in {cityName} may experience emergency
      plumbing issues due to aging infrastructure, environmental conditions,
      or unexpected system failures. Plumbing emergencies often occur without
      warning and require immediate professional attention.
    </p>

    <p>
      Emergency plumbing professionals are typically contacted for urgent
      situations involving active leaks, sewage issues, burst pipes, or loss
      of essential water services that cannot safely be delayed.
    </p>
  </section>

  <!-- SAFETY GUIDANCE -->
  <section>
    <h2>What to Do During a Plumbing Emergency</h2>
    <ul>
      <li>Shut off the main water supply if it is safe to do so</li>
      <li>Avoid using plumbing fixtures until the issue is assessed</li>
      <li>Keep electrical devices away from standing water</li>
      <li>Contact an emergency plumbing service for assistance</li>
    </ul>
  </section>

  <!-- FINAL CTA (GATED) -->
  <section class="final-cta">
    <h2>Need Emergency Plumbing Help in {cityName}?</h2>

    {intentConfig?.ctaEnabled && (
      <a href={intentConfig.phone} class="cta-button">
        Call Now for Emergency Plumbing Assistance
      </a>
    )}
  </section>

  <!-- INTERNAL GEO LINKS -->
  <section class="nearby-cities">
    <h2>Nearby Service Areas</h2>
    <ul>
      {nearbyCities.map((c) => (
        <li>
          <a href={`/emergency-plumbing/${c.slug}/`}>
            Emergency Plumbing in {c.city}, {c.state}
          </a>
        </li>
      ))}
    </ul>
  </section>

</BaseLayout>

