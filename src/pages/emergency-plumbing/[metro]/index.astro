---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import { supabase } from "@/lib/supabase";

/* =========================
   STATIC PATHS
========================= */
export async function getStaticPaths() {
  const { data, error } = await supabase
    .from("metros")
    .select("slug")
    .eq("is_active", true);

  if (error) throw new Error(error.message);

  return (data || []).map((m) => ({
    params: { metro: m.slug },
  }));
}

const { metro } = Astro.params;

/* =========================
   METRO CORE DATA
========================= */
const { data: metroData, error: metroError } = await supabase
  .from("metros")
  .select("name, state, region_name")
  .eq("slug", metro)
  .single();

if (metroError || !metroData) {
  throw new Error("Metro not found");
}

const city = metroData.name;
const state = metroData.state;
const region = metroData.region_name;

/* =========================
   METRO ATTRIBUTES
========================= */
const { data: attrs } = await supabase
  .from("metro_attributes")
  .select("*")
  .eq("metro_slug", metro)
  .maybeSingle();

const freezeRisk = attrs?.freeze_risk ?? false;
const coastalExposure = attrs?.coastal_salt_exposure ?? false;
const floodRisk = attrs?.flood_risk ?? false;
const agingInfrastructure = attrs?.aging_infrastructure ?? false;
const droughtConditions = attrs?.drought_conditions ?? false;

/* =========================
   FAQ FETCH
========================= */
let faqItems = [];

const { data: faqSet } = await supabase
  .from("faq_sets")
  .select("id")
  .eq("slug", "emergency-plumbing-core")
  .eq("language_code", "en")
  .maybeSingle();

if (faqSet?.id) {
  const { data } = await supabase
    .from("faq_items")
    .select("question, answer, position")
    .eq("faq_set_id", faqSet.id)
    .eq("is_active", true)
    .order("position", { ascending: true });

  faqItems = data || [];
}

/* =========================
   CTA CONTROL
========================= */

const verticalSlug = "emergency-plumbing";

let callsEnabled = false;
let phoneNumber = null;
let ctaLabel = "Call Now";
let ctaSubtext = "24/7 Emergency Service";

const { data: verticalData } = await supabase
  .from("verticals")
  .select("id")
  .eq("slug", verticalSlug)
  .single();

if (verticalData?.id) {
  const { data: ctaSettings } = await supabase
    .from("vertical_cta_settings")
    .select("calls_enabled")
    .eq("vertical_id", verticalData.id)
    .eq("language_code", "en")
    .maybeSingle();

  callsEnabled = ctaSettings?.calls_enabled ?? false;

  if (callsEnabled) {
    const { data: ctaProfile } = await supabase
      .from("cta_profiles")
      .select("phone_number, cta_label, cta_subtext, is_active")
      .eq("vertical_id", verticalData.id)
      .eq("language_code", "en")
      .maybeSingle();

    if (ctaProfile?.is_active && ctaProfile?.phone_number) {
      phoneNumber = ctaProfile.phone_number;
      ctaLabel = ctaProfile.cta_label ?? ctaLabel;
      ctaSubtext = ctaProfile.cta_subtext ?? ctaSubtext;
    } else {
      callsEnabled = false;
    }
  }
}
---

<BaseLayout title={`Emergency Plumbing in ${city}, ${state} | Luxesur`}>

  <Hero
    src="/images/emergency-plumbing/hero.webp"
    alt={`Emergency plumbing information for ${city}, ${state}`}
  >
    {callsEnabled && phoneNumber ? (
      <>
        <a href={`tel:${phoneNumber}`} class="hero-cta">
          {ctaLabel}
        </a>
        <small class="cta-note">{ctaSubtext}</small>
      </>
    ) : (
      <>
        <button class="hero-cta disabled">
          Emergency Plumbing Assistance
        </button>
        <small class="cta-note">
          Connection availability coming soon.
        </small>
      </>
    )}
  </Hero>

  <h1>Emergency Plumbing in {city}, {state}</h1>

  <p>
    Emergency plumbing assistance may be available in {city} and surrounding areas
    throughout the {region} region.
  </p>

  {freezeRisk && (
    <p>
      Seasonal temperature drops in {city} may increase the risk of frozen or burst pipes during colder months.
    </p>
  )}

  {coastalExposure && (
    <p>
      Coastal salt exposure in parts of {city} may contribute to gradual pipe corrosion over time.
    </p>
  )}

  {floodRisk && (
    <p>
      Heavy rainfall or storm systems affecting the {region} region may increase the likelihood of flooding-related plumbing emergencies.
    </p>
  )}

  {agingInfrastructure && (
    <p>
      Older infrastructure in certain areas of {city} may increase the risk of pipe failures or sewer backups.
    </p>
  )}

  {droughtConditions && (
    <p>
      Extended dry conditions in {state} can impact soil movement and underground plumbing systems.
    </p>
  )}

  <p>
    Luxesur is an informational and referral platform. We do not provide plumbing services directly.
  </p>

  {faqItems.length > 0 && (
    <section class="faq-section">
      <h2>Frequently Asked Questions</h2>
      {faqItems.map((faq) => (
        <div class="faq-item">
          <h3>{faq.question}</h3>
          <p>{faq.answer}</p>
        </div>
      ))}
    </section>
  )}

  {callsEnabled && phoneNumber ? (
    <div class="sticky-cta active">
      <a href={`tel:${phoneNumber}`}>{ctaLabel}</a>
      <small>{ctaSubtext}</small>
    </div>
  ) : (
    <div class="sticky-cta disabled">
      <span>Call to Connect With a Local Plumber</span>
      <small>Independent third-party providers • Availability varies</small>
    </div>
  )}

  {faqItems.length > 0 && (
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": faqItems.map((faq) => ({
          "@type": "Question",
          "name": faq.question,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.answer
          }
        }))
      })}
    </script>
  )}

</BaseLayout>