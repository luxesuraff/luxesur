---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { cities } from "@/data/cities";
import { INTENT_CONFIG, type IntentKey } from "@/config/intents";
import Hero from "@/components/Hero.astro";

export async function getStaticPaths() {
  return cities.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props;
const cityName = city.city;
const state = city.state;

// 🔒 LOCKED + TYPED INTENT
const intent: IntentKey = "burst-pipe";
const intentConfig = INTENT_CONFIG[intent];

const pageTitle = `Burst Pipe Repair in ${cityName}, ${state} | Emergency Plumbing Help`;
const metaDescription =
  `Dealing with a burst pipe in ${cityName}, ${state}? Learn how emergency plumbing services can help stop leaks, limit damage, and restore safe water service.`;

const currentIndex = cities.findIndex(c => c.slug === city.slug);
const nearbyCities = cities
  .slice(currentIndex + 1, currentIndex + 7)
  .filter(Boolean);
---

<BaseLayout title={pageTitle} description={metaDescription}>

  <!-- HERO (NO PHONE ON BURST PIPE) -->
  <Hero
    src="/images/emergency-plumbing/burst-pipe/hero.webp"
    alt={`Burst pipe repair in ${cityName}, ${state}`}
    phone={null}
  />

  <!-- INTRO -->
  <section class="hero">
    <h1>Burst Pipe Repair in {cityName}, {state}</h1>

    <p>
      A burst pipe can release large amounts of water in a short period of time,
      leading to damage to walls, flooring, and personal belongings. Immediate
      action is often required to prevent further loss.
    </p>

    <p>
      Burst pipe situations are considered plumbing emergencies and are
      typically handled by licensed emergency plumbing professionals serving
      {cityName}, {state}.
    </p>
  </section>

  <!-- CAUSES -->
  <section>
    <h2>What Causes Pipes to Burst?</h2>

    <p>
      Pipes can burst for a variety of reasons, often without warning.
      Older plumbing systems, sudden pressure changes, or environmental
      conditions may increase the risk.
    </p>

    <ul>
      <li>Freezing or extreme temperature changes</li>
      <li>Corroded or aging pipes</li>
      <li>Sudden increases in water pressure</li>
      <li>Previous damage or improper installation</li>
    </ul>
  </section>

  <!-- WHY EMERGENCY -->
  <section>
    <h2>Why a Burst Pipe Is a Plumbing Emergency</h2>

    <p>
      Water from a burst pipe can spread rapidly throughout a property,
      soaking building materials and creating conditions for structural
      damage or mold growth.
    </p>

    <p>
      Emergency plumbing response is often needed to stop water flow,
      stabilize the situation, and prevent additional damage.
    </p>
  </section>

  <!-- 🔗 PARENT SERVICE BRIDGE (CRITICAL FIX) -->
  <section>
    <h2>How Burst Pipe Emergencies Are Typically Handled in {cityName}, {state}</h2>

    <p>
      Burst pipe emergencies are typically addressed by emergency plumbing
      professionals who are equipped to respond quickly and assess the
      severity of the situation.
    </p>

    <p>
      Emergency plumbing response may involve shutting off water supply,
      isolating the damaged pipe, performing temporary or permanent repairs,
      and advising on next steps to restore safe plumbing operation.
    </p>
  </section>

  <!-- FUNNEL CONNECTOR (NO PHONE) -->
  <section>
    <h3>Emergency Plumbing Help for Burst Pipe Situations</h3>

    <p>
      Because burst pipes require immediate attention, emergency plumbing
      services are often needed to prevent further property damage and
      restore safe water flow.
    </p>

    <a href={`/emergency-plumbing/${city.slug}/`} class="cta-button">
      Get Emergency Plumbing Help in {cityName}
    </a>
  </section>

  <!-- LOCAL CONTEXT -->
  <section>
    <h2>Burst Pipe Issues in {cityName}, {state}</h2>

    <p>
      Properties in {cityName} may experience burst pipe issues due to
      seasonal weather, aging infrastructure, or unexpected plumbing failures.
    </p>

    <p>
      Emergency plumbing professionals familiar with local conditions can
      respond to urgent burst pipe situations when they occur.
    </p>
  </section>

  <!-- TRUST FRAMING -->
  <section>
    <h2>Get Help From Qualified Emergency Plumbing Professionals</h2>

    <p>
      Burst pipe emergencies are typically handled by licensed and insured
      emergency plumbing professionals experienced in addressing urgent
      water-related issues.
    </p>

    <p>
      Acting quickly can help reduce the impact of water damage and protect
      your property.
    </p>
  </section>

  <!-- NEARBY CITIES (KEEP INTENT-SPECIFIC) -->
  <section class="nearby-cities">
    <h2>Nearby Service Areas</h2>
    <ul>
      {nearbyCities.map((c) => (
        <li>
          <a href={`/emergency-plumbing/burst-pipe/${c.slug}/`}>
            Burst Pipe Repair in {c.city}, {c.state}
          </a>
        </li>
      ))}
    </ul>
  </section>

</BaseLayout>
