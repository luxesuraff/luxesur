---
import { supabase } from "../../lib/supabase";
import { getContentBlocks } from "../../lib/getContentBlocks";
import { renderTemplate } from "../../lib/renderTemplate";
import { selectVariant } from "../../lib/selectVariant";

/**
 * 🔹 BUILD-TIME PATHS
 */
export async function getStaticPaths() {
  const { data: metros } = await supabase
    .from("metros")
    .select("slug")
    .eq("is_active", true)
    .limit(10); // TEMP LIMIT for testing

  return metros.map((m) => ({
    params: { metro: m.slug },
  }));
}

/**
 * 🔹 RUNTIME PAGE
 */
const { metro } = Astro.params;

// Load metro
const { data: metroRow } = await supabase
  .from("metros")
  .select("name, region_name, slug")
  .eq("slug", metro)
  .single();

if (!metroRow) {
  throw new Error("Metro not found");
}

// Load content
const blocks = await getContentBlocks({
  verticalId: "8d1074a0-37c0-4db1-9596-7fa2c48fa5a1",
  languageCode: "en",
  regionId: null,
});

// Group blocks
const grouped = {};
for (const block of blocks) {
  grouped[block.block_type] ||= [];
  grouped[block.block_type].push(block);
}

// Deterministic select
const selectedBlocks = Object.values(grouped).map((variants) =>
  selectVariant(variants, metroRow.slug)
);
---

<h1>Emergency Plumbing in {metroRow.name}</h1>

{selectedBlocks.map((block) => (
  <section style="margin-bottom: 32px;">
    <h3>{block.block_type}</h3>
    <p>
      {renderTemplate(block.template.template_text, {
        metro_name: metroRow.name,
        region_name: metroRow.region_name,
      })}
    </p>
  </section>
))}