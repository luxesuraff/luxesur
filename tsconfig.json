{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["astro/client"]
  },
  "include": [
    ".astro/types.d.ts",
    "src",
    "**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
